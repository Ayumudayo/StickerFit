{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StickerFit",
  "version": "0.1.0",
  "identifier": "com.stickerfit.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "StickerFit Desktop",
        "width": 1180,
        "height": 820,
        "minWidth": 1100,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "binaries/libwinpthread-1.dll"
    ],
    "externalBin": [
      "binaries/ffmpeg"
    ]
  }
}
