{
  "name": "stickerfit-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:desktop": "tauri dev",
    "build": "tsc && vite build",
    "build:web": "tsc && vite build",
    "build:desktop": "tauri build",
    "test": "npm run test:unit && npm run test:rust",
    "test:unit": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml -- --nocapture",
    "test:web-smoke": "playwright test",
    "check:beta": "npm run build:web && npm run build:desktop && npm run test:unit && npm run test:rust && npm run test:web-smoke",
    "report:size": "powershell -ExecutionPolicy Bypass -File tools/size-report.ps1",
    "ffmpeg:build-minimal": "powershell -ExecutionPolicy Bypass -File tools/ffmpeg/build-minimal-ffmpeg.ps1",
    "bootstrap:windows": "powershell -ExecutionPolicy Bypass -File tools/bootstrap-build-windows.ps1",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.0"
  }
}
